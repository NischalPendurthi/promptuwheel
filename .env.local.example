# Copy this file to .env.local and fill in your Upstash credentials.
# Get these from: Vercel Dashboard → Storage → your Upstash Redis DB → .env.local tab
# (or from console.upstash.com → your database → REST API section)

UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here
